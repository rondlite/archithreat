<?xml version="1.0" encoding="UTF-8"?>
<model xmlns="http://www.opengroup.org/xsd/archimate/3.0/"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       identifier="lemonade-shop-1">
  <name xml:lang="en">Lemonade Shop</name>
  <documentation xml:lang="en">A small online lemonade shop architecture: customer browses on the web, places orders, payment processed via external gateway, kitchen tablet receives orders.</documentation>
  <propertyDefinitions>
    <propertyDefinition identifier="propdef_zone_type" type="string">
      <name xml:lang="en">zone_type</name>
    </propertyDefinition>
    <propertyDefinition identifier="propdef_tech_stack" type="string">
      <name xml:lang="en">tech_stack</name>
    </propertyDefinition>
    <propertyDefinition identifier="propdef_protocol" type="string">
      <name xml:lang="en">protocol</name>
    </propertyDefinition>
    <propertyDefinition identifier="propdef_data_classification" type="string">
      <name xml:lang="en">data_classification</name>
    </propertyDefinition>
  </propertyDefinitions>

  <elements>
    <!-- Trust zones -->
    <element identifier="z_internet" xsi:type="Grouping">
      <name xml:lang="en">Internet</name>
      <properties>
        <property propertyDefinitionRef="propdef_zone_type">
          <value xml:lang="en">logical</value>
        </property>
      </properties>
    </element>
    <element identifier="z_dmz" xsi:type="Grouping">
      <name xml:lang="en">DMZ</name>
      <properties>
        <property propertyDefinitionRef="propdef_zone_type">
          <value xml:lang="en">logical</value>
        </property>
      </properties>
    </element>
    <element identifier="z_internal" xsi:type="Grouping">
      <name xml:lang="en">Internal Network</name>
      <properties>
        <property propertyDefinitionRef="propdef_zone_type">
          <value xml:lang="en">logical</value>
        </property>
      </properties>
    </element>
    <element identifier="z_payments" xsi:type="Grouping">
      <name xml:lang="en">Payment Provider</name>
      <properties>
        <property propertyDefinitionRef="propdef_zone_type">
          <value xml:lang="en">logical</value>
        </property>
      </properties>
    </element>
    <element identifier="z_shop" xsi:type="Grouping">
      <name xml:lang="en">Shop Floor</name>
      <properties>
        <property propertyDefinitionRef="propdef_zone_type">
          <value xml:lang="en">logical</value>
        </property>
      </properties>
    </element>

    <!-- Hosts -->
    <element identifier="n_webserver" xsi:type="Node">
      <name xml:lang="en">web-server-1</name>
    </element>
    <element identifier="n_appserver" xsi:type="Node">
      <name xml:lang="en">app-server-1</name>
    </element>
    <element identifier="n_dbserver" xsi:type="Node">
      <name xml:lang="en">db-server-1</name>
    </element>
    <element identifier="n_tablet" xsi:type="Device">
      <name xml:lang="en">kitchen-tablet</name>
    </element>
    <element identifier="n_paygw" xsi:type="Node">
      <name xml:lang="en">payment-gateway-host</name>
    </element>

    <!-- Application components -->
    <element identifier="a_storefront" xsi:type="ApplicationComponent">
      <name xml:lang="en">Storefront</name>
      <properties>
        <property propertyDefinitionRef="propdef_tech_stack">
          <value xml:lang="en">web</value>
        </property>
      </properties>
    </element>
    <element identifier="a_orderapi" xsi:type="ApplicationComponent">
      <name xml:lang="en">Order API</name>
    </element>
    <element identifier="a_inventory" xsi:type="ApplicationComponent">
      <name xml:lang="en">Inventory Service</name>
    </element>
    <element identifier="a_kitchenui" xsi:type="ApplicationComponent">
      <name xml:lang="en">Kitchen Display</name>
      <properties>
        <property propertyDefinitionRef="propdef_tech_stack">
          <value xml:lang="en">mobile</value>
        </property>
      </properties>
    </element>
    <element identifier="a_paygw" xsi:type="ApplicationComponent">
      <name xml:lang="en">Stripe Gateway</name>
    </element>

    <!-- Data -->
    <element identifier="d_orders" xsi:type="DataObject">
      <name xml:lang="en">Orders DB</name>
      <properties>
        <property propertyDefinitionRef="propdef_data_classification">
          <value xml:lang="en">internal</value>
        </property>
      </properties>
    </element>
    <element identifier="d_inventory" xsi:type="DataObject">
      <name xml:lang="en">Inventory DB</name>
    </element>

    <!-- Actors -->
    <element identifier="ba_customer" xsi:type="BusinessActor">
      <name xml:lang="en">Customer</name>
    </element>
    <element identifier="ba_kitchen" xsi:type="BusinessActor">
      <name xml:lang="en">Kitchen Staff</name>
    </element>
  </elements>

  <relationships>
    <!-- Containment of hosts in zones -->
    <relationship identifier="rc_web_dmz" xsi:type="Composition" source="z_dmz" target="n_webserver"/>
    <relationship identifier="rc_app_int" xsi:type="Composition" source="z_internal" target="n_appserver"/>
    <relationship identifier="rc_db_int" xsi:type="Composition" source="z_internal" target="n_dbserver"/>
    <relationship identifier="rc_tablet_shop" xsi:type="Composition" source="z_shop" target="n_tablet"/>
    <relationship identifier="rc_paygw_pay" xsi:type="Composition" source="z_payments" target="n_paygw"/>
    <relationship identifier="rc_cust_inet" xsi:type="Composition" source="z_internet" target="ba_customer"/>

    <!-- Realizations -->
    <relationship identifier="rr_storefront" xsi:type="Realization" source="a_storefront" target="n_webserver"/>
    <relationship identifier="rr_orderapi" xsi:type="Realization" source="a_orderapi" target="n_appserver"/>
    <relationship identifier="rr_inventory" xsi:type="Realization" source="a_inventory" target="n_appserver"/>
    <relationship identifier="rr_kitchenui" xsi:type="Realization" source="a_kitchenui" target="n_tablet"/>
    <relationship identifier="rr_paygw" xsi:type="Realization" source="a_paygw" target="n_paygw"/>

    <!-- Data hosting -->
    <relationship identifier="ra_orders_db" xsi:type="Access" source="a_orderapi" target="d_orders" accessType="write"/>
    <relationship identifier="ra_inv_db" xsi:type="Access" source="a_inventory" target="d_inventory" accessType="write"/>

    <!-- Flows -->
    <relationship identifier="rf_cust_storefront" xsi:type="Flow" source="ba_customer" target="a_storefront">
      <properties>
        <property propertyDefinitionRef="propdef_protocol">
          <value xml:lang="en">HTTPS</value>
        </property>
      </properties>
    </relationship>
    <relationship identifier="rf_storefront_order" xsi:type="Flow" source="a_storefront" target="a_orderapi">
      <properties>
        <property propertyDefinitionRef="propdef_protocol">
          <value xml:lang="en">HTTPS</value>
        </property>
      </properties>
    </relationship>
    <relationship identifier="rf_order_inv" xsi:type="Flow" source="a_orderapi" target="a_inventory">
      <properties>
        <property propertyDefinitionRef="propdef_protocol">
          <value xml:lang="en">gRPC</value>
        </property>
      </properties>
    </relationship>
    <relationship identifier="rf_order_pay" xsi:type="Flow" source="a_orderapi" target="a_paygw">
      <properties>
        <property propertyDefinitionRef="propdef_protocol">
          <value xml:lang="en">HTTPS</value>
        </property>
      </properties>
    </relationship>
    <relationship identifier="rf_order_kitchen" xsi:type="Flow" source="a_orderapi" target="a_kitchenui">
      <properties>
        <property propertyDefinitionRef="propdef_protocol">
          <value xml:lang="en">WebSocket</value>
        </property>
      </properties>
    </relationship>
    <relationship identifier="rs_kitchen_staff" xsi:type="Serving" source="a_kitchenui" target="ba_kitchen"/>
  </relationships>
</model>
