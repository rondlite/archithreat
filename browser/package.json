{
  "name": "archithreat-browser",
  "version": "3.2.0",
  "private": true,
  "description": "archithreat browser shell — static site running the conversion core entirely in the user's browser via Pyodide.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs && node scripts/serve.mjs",
    "serve": "node scripts/serve.mjs",
    "vendor:pyodide": "node scripts/vendor-pyodide.mjs",
    "vendor:drawio": "node scripts/vendor-drawio.mjs",
    "vendor:all": "npm run vendor:pyodide && npm run vendor:drawio",
    "build:wheel": "cd .. && python -m build --wheel --outdir browser/dist/wheels/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
